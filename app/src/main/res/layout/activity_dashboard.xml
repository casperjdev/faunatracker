<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSecondary"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".dashboard.DashboardActivity">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top App Bar -->
        <include layout="@layout/component_home_navbar" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1sp"
            android:layout_marginStart="16sp"
            android:layout_marginEnd="16sp"
            android:background="?attr/colorTertiary"
            />

        <TextView
            android:id="@+id/dashboard_greeting"
            android:layout_width="wrap_content"
            android:layout_height="32sp"
            android:textSize="24sp"
            android:layout_margin="16sp"
            android:textColor="?attr/colorPrimary"
            />

        <FrameLayout
            android:id="@+id/contentFrame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/dashboard_placeholder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16sp">
                <ImageView
                    android:layout_width="196dp"
                    android:layout_height="96dp"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/logo"
                    app:tint="?attr/colorPrimaryVariant" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="@string/dashboard_placeholder"
                    android:textColor="?attr/colorPrimaryVariant"
                    android:textSize="16sp"
                    android:textStyle="normal"
                    android:textAlignment="center"
                    />
            </LinearLayout>

            <!-- RecyclerView for studies -->

            <LinearLayout
                android:id="@+id/dashboard_list_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Saved Studies"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_margin="16sp"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/dashboard_list"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </LinearLayout>

            <!-- Loading -->
            <FrameLayout
                android:id="@+id/loadingOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/colorSecondaryVariant"
                android:visibility="gone"
                >
                <ProgressBar
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:elevation="1dp"
                    android:indeterminateTint="?attr/colorPrimary"/>
            </FrameLayout>

        </FrameLayout>


    </LinearLayout>

    <!-- Floating Search Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/dashboard_search"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="32dp"
        android:paddingStart="12sp"
        android:paddingEnd="12sp"
        app:backgroundTint="?attr/colorPrimary"
        android:contentDescription="@string/dashboard_search_desc"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:icon="@drawable/search"
        app:iconSize="24sp"
        app:iconTint="?attr/colorSecondary"
        android:text="Find Studies"
        android:textColor="?attr/colorSecondary"
        app:rippleColor="?attr/colorSecondary"
        >
    </com.google.android.material.button.MaterialButton>
</androidx.constraintlayout.widget.ConstraintLayout>