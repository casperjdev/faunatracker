<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="?attr/colorSecondary"
    android:id="@+id/rootLayout"
    tools:context=".map.MapActivity">

    <!-- HEADER -->
    <FrameLayout
        android:id="@+id/navbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/map_nav_bg"
        android:elevation="8dp"
        android:padding="16sp">
        <TextView
            android:id="@+id/navbarText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:ellipsize="marquee"
            android:fadingEdge="horizontal"
            android:maxLines="1"
            android:singleLine="true"
            android:marqueeRepeatLimit="marquee_forever"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:scrollHorizontally="true"
            android:freezesText="true"
            />

    </FrameLayout>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- MAP VIEW -->
        <org.maplibre.android.maps.MapView
            android:id="@+id/mapView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <FrameLayout
            android:id="@+id/mapLoading"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/colorSecondaryVariant"
            android:visibility="gone"
            android:elevation="16sp"
            >
            <ProgressBar
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:elevation="1dp"
                android:indeterminateTint="?attr/colorPrimary"/>
        </FrameLayout>

        <!-- scrim over the map, fades in as sheet expands -->
        <View
            android:id="@+id/mapScrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/colorSecondary"
            android:alpha="0"/>

        <!-- BOTTOM SHEET -->
        <LinearLayout
            android:id="@+id/bottomSheet"
            android:orientation="vertical"
            android:background="?attr/colorSecondary"
            app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
                <!-- DRAG HANDLE -->
                <LinearLayout
                    android:id="@+id/thumb"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:background="@android:color/transparent">
                    <View
                        android:layout_width="40dp"
                        android:layout_height="4dp"
                        android:background="@drawable/drag_handle" />
                </LinearLayout>

                <!-- HALF-EXPANDED HEADER (horizontal) -->
                <LinearLayout
                    android:id="@+id/headerRow"
                    android:layout_width="match_parent"
                    android:layout_height="96dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12sp">
                    <androidx.cardview.widget.CardView
                        android:id="@+id/speciesCard"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12sp"
                        app:cardCornerRadius="16sp"
                        android:elevation="0sp">
                        <ImageView
                            android:id="@+id/speciesImage"
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:contentDescription="Species"
                            android:scaleType="centerCrop"
                            />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/speciesName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorPrimary"
                            android:ellipsize="marquee"
                            android:fadingEdge="horizontal"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:scrollHorizontally="true"
                            android:freezesText="true"
                            android:marqueeRepeatLimit="marquee_forever"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            />
                        <TextView
                            android:id="@+id/speciesNameLatin"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="16sp"
                            android:textStyle="normal"
                            android:textColor="?attr/colorPrimaryVariant"
                            android:ellipsize="marquee"
                            android:fadingEdge="horizontal"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:scrollHorizontally="true"
                            android:freezesText="true"
                            android:marqueeRepeatLimit="marquee_forever"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            />
                    </LinearLayout>
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/contentLoading"
                    android:layout_width="match_parent"
                    android:layout_height="96dp"
                    android:background="?attr/colorSecondaryVariant"
                    android:visibility="gone"
                    >
                    <ProgressBar
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:elevation="1dp"
                        android:indeterminateTint="?attr/colorPrimary"/>
                </FrameLayout>

                <!-- FULL EXPANDED CONTENT -->
                <androidx.core.widget.NestedScrollView
                    android:id="@+id/wikiScroll"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:fillViewport="true"
                    android:layout_weight="1"
                    android:paddingStart="16sp"
                    android:paddingEnd="16sp"
                    android:fadingEdge="vertical"
                    android:requiresFadingEdge="vertical"
                    android:fadingEdgeLength="16sp">

                    <TextView
                        android:id="@+id/wikiContent"
                        android:textColor="?attr/colorPrimary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="16sp" />

                </androidx.core.widget.NestedScrollView>

                <!-- BUTTONS TRAY -->
                <LinearLayout
                    android:id="@+id/actionTray"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_gravity="bottom"
                    android:padding="16sp">

                    <LinearLayout
                        android:layout_width="0sp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_gravity="center_vertical"
                        android:gravity="center">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSave"
                            app:cornerRadius="32sp"
                            android:layout_width="48sp"
                            android:layout_height="48sp"
                            app:backgroundTint="?attr/colorPrimary"
                            android:textColor="?attr/colorSecondary"
                            app:rippleColor="?attr/colorSecondary"
                            app:icon="@drawable/pin"
                            app:iconTint="?attr/colorSecondary"
                            app:iconSize="24sp"
                            app:iconPadding="0dp"
                            app:iconGravity="textStart"
                            android:insetLeft="0dp"
                            android:insetTop="0dp"
                            android:insetRight="0dp"
                            android:insetBottom="0dp"/>

                        <TextView
                            android:id="@+id/btnSaveLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Pin"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:layout_marginTop="12sp"
                            android:ellipsize="marquee" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0sp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_gravity="center_vertical"
                        android:gravity="center">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFindSimilar"
                            app:cornerRadius="32sp"
                            android:layout_width="48sp"
                            android:layout_height="48sp"
                            app:backgroundTint="?attr/colorPrimary"
                            android:textColor="?attr/colorSecondary"
                            app:rippleColor="?attr/colorSecondary"
                            app:icon="@drawable/search"
                            app:iconTint="?attr/colorSecondary"
                            app:iconSize="24sp"
                            app:iconPadding="0dp"
                            app:iconGravity="textStart"
                            android:insetLeft="0dp"
                            android:insetTop="0dp"
                            android:insetRight="0dp"
                            android:insetBottom="0dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Find Similar"
                            android:breakStrategy="balanced"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:layout_marginTop="12sp" />
                    </LinearLayout>


                    <!-- <LinearLayout
                        android:layout_width="0sp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
