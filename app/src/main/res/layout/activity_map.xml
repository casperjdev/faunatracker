                    </LinearLayout> -->

                </LinearLayout>

                <View
                    android:id="@+id/bottomNavInsetSpacer"
                    android:layout_width="match_parent"
                    android:layout_height="0dp" />
        </LinearLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</FrameLayout>