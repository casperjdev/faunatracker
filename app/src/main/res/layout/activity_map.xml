<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="?attr/colorSecondary"
    android:id="@+id/rootLayout"
    tools:context=".map.MapActivity">

    <!-- HEADER -->
    <RelativeLayout
        android:id="@+id/navbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="?attr/colorSecondary"
        android:padding="16sp"
        android:elevation="8dp">
        <TextView
            android:id="@+id/navbarText"
            android:layout_width="match_parent"
            android:layout_marginEnd="40sp"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:ellipsize="marquee"
            android:fadingEdge="horizontal"
            android:maxLines="1"
            android:singleLine="true"
            android:marqueeRepeatLimit="marquee_forever"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:scrollHorizontally="true"
            android:freezesText="true"
            />
        <ImageButton
            android:id="@+id/nav_settings"
            android:layout_width="24sp"
            android:layout_height="24sp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/settings"
            android:contentDescription="Settings"
            android:background="@android:color/transparent"
            app:tint="?attr/colorPrimary"
            />
    </RelativeLayout>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- MAP VIEW -->
        <org.maplibre.android.maps.MapView
            android:id="@+id/mapView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <FrameLayout
            android:id="@+id/mapLoading"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/colorSecondaryVariant"
            android:visibility="gone"
            >
            <ProgressBar
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:elevation="1dp"
                android:indeterminateTint="?attr/colorPrimary"/>
        </FrameLayout>

        <!-- BOTTOM SHEET -->
        <LinearLayout
            android:id="@+id/bottomSheet"
            android:orientation="vertical"
            android:background="?attr/colorSecondary"
            app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- DRAG HANDLE -->
            <LinearLayout
                android:id="@+id/thumb"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:gravity="center"
                android:background="@android:color/transparent">
                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:background="@drawable/drag_handle" />
            </LinearLayout>

            <!-- HALF-EXPANDED HEADER (horizontal) -->
            <LinearLayout
                android:id="@+id/headerRow"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:id="@+id/speciesImage"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:contentDescription="Species"
                    android:scaleType="centerCrop"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/speciesName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorPrimary"
                        android:ellipsize="marquee"
                        android:fadingEdge="horizontal"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:scrollHorizontally="true"
                        android:freezesText="true"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        />
                    <TextView
                        android:id="@+id/speciesNameLatin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textStyle="normal"
                        android:textColor="?attr/colorPrimaryVariant"
                        android:ellipsize="marquee"
                        android:fadingEdge="horizontal"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:scrollHorizontally="true"
                        android:freezesText="true"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        />
                </LinearLayout>
            </LinearLayout>

            <FrameLayout
                android:id="@+id/contentLoading"
                android:layout_width="match_parent"
                android:layout_height="72sp"
                android:background="?attr/colorSecondaryVariant"
                android:visibility="gone"
                >
                <ProgressBar
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:elevation="1dp"
                    android:indeterminateTint="?attr/colorPrimary"/>
            </FrameLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1sp"
                android:layout_marginStart="16sp"
                android:layout_marginEnd="16sp"
                android:layout_marginTop="16sp"
                android:background="?attr/colorTertiary"
                />

            <!-- FULL EXPANDED CONTENT -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/wikiScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fillViewport="true"
                android:padding="16dp">

                <TextView
                    android:id="@+id/wikiContent"
                    android:textColor="?attr/colorPrimary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp" />

            </androidx.core.widget.NestedScrollView>

            <!-- Add padding for gesture navigation insets -->
            <View
                android:id="@+id/bottomNavInsetSpacer"
                android:layout_width="match_parent"
                android:layout_height="0dp" />

        </LinearLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</LinearLayout>